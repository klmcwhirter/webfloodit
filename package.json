{
  "name": "webfloodit-ui",
  "version": "1.0.0",
  "description": "Floodit as a web application",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "up": "rm -fr node_modules/ && docker compose build --no-cache && docker compose up",
    "clean": "rm -fr node_modules/ && docker buildx prune -af && docker system prune -af --volumes"
  },
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-solid": "^2.11.11"
  },
  "dependencies": {
    "shuffle-array": "^1.0.1",
    "solid-js": "^1.9.12"
  }
}
